   "source": [
    "def add(a,b):\n",
    "    return a+b\n",
    "\n",
    "def sub(a,b):\n",
    "    return a-b\n",
    "\n",
    "def mul(a,b):\n",
    "    return a*b\n",
    "\n",
    "def div(a,b):\n",
    "    if b== 0:\n",
    "        return \"Cannot divide by zero\"\n",
    "    return a/b\n",
    "\n",
    "print(add(20,10))\n",
    "print(sub(20,10))\n",
    "print(mul(20,10))\n",
    "print(div(20,10))\n",
    "print(div(20,0))"
   ]
